VITE_MOIS_API_KEY=
VITE_NEC_API_KEY=
VITE_SEOUL_OPEN_API_KEY=
VITE_SGIS_SERVICE_ID=
VITE_SGIS_SECURITY_KEY=
VITE_DATA_SOURCE_MODE=mock
VITE_USE_HASH_ROUTER=false
VITE_DEBUG_DATA_SOURCES=false
# MOIS: use a same-origin proxy path in dev/prod because jumin.mois.go.kr blocks browser CORS.
VITE_MOIS_API_BASE_URL=/mois
VITE_MOIS_API_PATH=resident-population
# NEC: use a same-origin proxy path to surface approval_required / 403 cleanly in the browser.
VITE_NEC_API_BASE_URL=/nec
VITE_NEC_API_PATH=winner-info
VITE_SEOUL_OPEN_API_BASE_URL=
# SGIS: real boundary host and optional auth/boundary path overrides.
VITE_SGIS_API_BASE_URL=
VITE_SGIS_AUTH_PATH=
VITE_SGIS_BOUNDARY_PATH=
VITE_SGIS_BOUNDARY_YEAR=2025
# Off by default. Generated grid boundaries are for development fallback only.
VITE_ENABLE_GENERATED_BOUNDARY_FALLBACK=false
